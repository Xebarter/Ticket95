# ===========================================
# Supabase Configuration
# ===========================================
# Get these values from your Supabase project settings
# Dashboard: https://supabase.com/dashboard/projects
# Navigate to: Settings > API

# Your Supabase project URL (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public anon key (Required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key for server-side operations
# ⚠️ NEVER expose this in frontend code - server-side only!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Application Configuration
# ===========================================

# Application URL (Required for auth redirects)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Email Configuration (Supabase Settings)
# ===========================================
# Configure these in Supabase Dashboard > Authentication > Email Templates
# 
# Email Templates to configure:
# 1. Confirm signup
# 2. Reset password
# 3. Magic Link
# 4. Change email address
# 5. Invite user
#
# Redirect URLs to add in Supabase Dashboard > Authentication > URL Configuration:
# - http://localhost:3000/auth/verify-email (development)
# - http://localhost:3000/auth/reset-password (development)
# - https://your-domain.com/auth/verify-email (production)
# - https://your-domain.com/auth/reset-password (production)
